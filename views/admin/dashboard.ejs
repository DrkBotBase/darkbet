<%- include('../partials/header') %>

<!-- AÑADIR: Librerías de Flatpickr -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/dark.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<div class="max-w-6xl mx-auto">
  <!-- Dashboard Header -->
  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-8">
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-white flex items-center gap-2">
        <i class="fa-solid fa-gauge-high text-yellow-400"></i>Panel de Administración
      </h1>
      <p class="text-purple-200/50 text-sm mt-1">
        Gestiona tus predicciones, actualiza estados y sube evidencias.
      </p>
    </div>
    
    <a 
      href="/admin/crear" 
      class="inline-flex items-center justify-center space-x-2 px-5 py-3 bg-gradient-to-r from-yellow-400 to-orange-500 text-slate-950 font-bold rounded-xl shadow-md hover:from-yellow-350 hover:to-orange-450 transition transform active:scale-95 text-sm self-start sm:self-auto"
    >
      <i class="fa-solid fa-plus-circle text-base"></i>
      <span>Crear Nueva Predicción</span>
    </a>
  </div>

  <!-- Filters - MODIFICADO -->
  <div class="flex flex-wrap gap-4 mb-6 items-center">
    <form action="/admin/dashboard" method="GET" class="flex items-center gap-2" id="filterForm">
      <input type="hidden" name="estado" value="<%= currentFilter %>">
      <input 
        type="text"
        name="date" 
        id="dateFilter"
        value="<%= selectedDate %>"
        class="bg-white/5 border border-white/10 rounded-xl text-white text-xs px-3 py-2 focus:outline-none w-40"
        readonly
        placeholder="Selecciona fecha"
      >
      <button type="submit" class="px-4 py-2 rounded-xl text-xs font-semibold bg-yellow-400 text-slate-950 border border-yellow-400 hover:bg-yellow-350 transition">
        Filtrar
      </button>
      <a href="/admin/dashboard" class="px-4 py-2 rounded-xl text-xs font-semibold bg-white/5 border border-white/10 text-purple-200/80 hover:bg-white/10 transition">
        Limpiar
      </a>
    </form>
    
    <div class="h-6 w-px bg-white/10 hidden sm:block"></div>

    <div class="flex gap-2">
      <a 
        href="/admin/dashboard?date=<%= selectedDate %>" 
        class="px-4 py-2 rounded-xl text-xs font-semibold border transition duration-150 <%= !currentFilter ? 'bg-yellow-400 text-slate-950 border-yellow-400' : 'bg-white/5 border-white/10 text-purple-200/80 hover:bg-white/10' %>"
      >
        Todas
      </a>
      <a 
        href="/admin/dashboard?date=<%= selectedDate %>&estado=pendiente" 
        class="px-4 py-2 rounded-xl text-xs font-semibold border transition duration-150 <%= currentFilter === 'pendiente' ? 'bg-yellow-500/20 text-yellow-400 border-yellow-400' : 'bg-white/5 border-white/10 text-purple-200/80 hover:bg-white/10' %>"
      >
        Pendientes
      </a>
      <a 
        href="/admin/dashboard?date=<%= selectedDate %>&estado=ganada" 
        class="px-4 py-2 rounded-xl text-xs font-semibold border transition duration-150 <%= currentFilter === 'ganada' ? 'bg-green-500/20 text-green-400 border-green-400' : 'bg-white/5 border-white/10 text-purple-200/80 hover:bg-white/10' %>"
      >
        Ganadas
      </a>
      <a 
        href="/admin/dashboard?date=<%= selectedDate %>&estado=perdida" 
        class="px-4 py-2 rounded-xl text-xs font-semibold border transition duration-150 <%= currentFilter === 'perdida' ? 'bg-red-500/20 text-red-400 border-red-400' : 'bg-white/5 border-white/10 text-purple-200/80 hover:bg-white/10' %>"
      >
        Perdidas
      </a>
    </div>
  </div>

  <!-- Predictions Table Container -->
  <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl overflow-hidden shadow-xl mb-6">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="border-b border-white/10 bg-black/30 text-purple-200/80 text-xs font-bold uppercase tracking-wider">
            <th class="px-6 py-4">Encuentro</th>
            <th class="px-6 py-4">Fecha / Hora</th>
            <th class="px-6 py-4">Predicción</th>
            <th class="px-6 py-4">Cuota</th>
            <th class="px-6 py-4">Estado</th>
            <th class="px-6 py-4">Imagen</th>
            <th class="px-6 py-4 text-center">Acciones</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/5 text-sm">
          <% if (predictions && predictions.length > 0) { %>
            <% predictions.forEach(pred => { %>
              <tr class="hover:bg-white/[0.02] transition">
                <!-- Encounter -->
                <td class="px-6 py-4 font-semibold text-white">
                  <%= pred.encuentro %>
                </td>
                
                <!-- Date/Time -->
                <td class="px-6 py-4 whitespace-nowrap text-purple-200/80">
                  <div class="font-medium"><%= moment(pred.fecha).utcOffset(-5).format('DD/MM/YYYY') %></div>
                  <div class="text-xs text-purple-200/50 flex items-center gap-1 mt-0.5">
                    <i class="fa-regular fa-clock"></i><%= pred.hora %>
                  </div>
                </td>
                
                <!-- Prediction details -->
                <td class="px-6 py-4 max-w-xs text-purple-100 font-medium truncate">
                  <%= pred.prediccion %>
                </td>
                
                <!-- Odds -->
                <td class="px-6 py-4 font-bold text-yellow-400">
                  <%= pred.cuota %>
                </td>
                
                <!-- Status badge -->
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if (pred.estado === 'pendiente') { %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-yellow-500/20 text-yellow-400 border border-yellow-400/20">
                      Pendiente
                    </span>
                  <% } else if (pred.estado === 'ganada') { %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-green-500/20 text-green-400 border border-green-400/20">
                      ✓ Ganada
                    </span>
                  <% } else if (pred.estado === 'perdida') { %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-red-500/20 text-red-400 border border-red-400/20">
                      ✗ Perdida
                    </span>
                  <% } %>
                </td>
                
                <!-- Image indicator -->
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if (pred.imagenUrl) { %>
                    <button 
                      type="button"
                      data-img-url="<%= pred.imagenUrl %>"
                      class="view-img-btn text-xs text-yellow-400 hover:underline flex items-center gap-1 font-medium"
                    >
                      <i class="fa-solid fa-image text-sm text-purple-400"></i>Ver Imagen
                    </button>
                  <% } else { %>
                    <span class="text-xs text-purple-200/30">— Sin Imagen</span>
                  <% } %>
                </td>
                
                <!-- Actions -->
                <td class="px-6 py-4 whitespace-nowrap text-center">
                  <div class="flex items-center justify-center space-x-2">
                    <!-- Edit Button -->
                    <a 
                      href="/admin/editar/<%= pred._id %>" 
                      class="p-2 bg-yellow-400/10 text-yellow-400 border border-yellow-400/20 rounded-lg hover:bg-yellow-400 hover:text-slate-950 transition-colors"
                      title="Editar"
                    >
                      <i class="fa-solid fa-pen-to-square text-sm"></i>
                    </a>
                    
                    <!-- Delete Button Form -->
                    <form 
                      action="/admin/eliminar/<%= pred._id %>?_method=DELETE" 
                      method="POST" 
                      onsubmit="return confirm('¿Está seguro de que desea eliminar permanentemente esta predicción? Se borrará también su imagen de Cloudinary.');"
                      class="inline"
                    >
                      <button 
                        type="submit" 
                        class="p-2 bg-red-600/10 text-red-400 border border-red-500/20 rounded-lg hover:bg-red-600 hover:text-white transition-colors"
                        title="Eliminar"
                      >
                        <i class="fa-solid fa-trash text-sm"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="7" class="px-6 py-12 text-center text-purple-200/50">
                <i class="fa-solid fa-folder-open text-4xl text-purple-200/20 mb-3 block"></i>
                No se encontraron predicciones en esta lista.
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
    <div class="flex justify-center items-center gap-2 my-8">
      <!-- Previous Page -->
      <% if (currentPage > 1) { %>
        <a 
          href="/admin/dashboard?page=<%= currentPage - 1 %>&date=<%= selectedDate %><%= currentFilter ? '&estado=' + currentFilter : '' %>" 
          class="px-3.5 py-2 rounded-lg bg-white/5 border border-white/10 hover:bg-white/10 text-purple-100 transition text-sm"
        >
          <i class="fa-solid fa-chevron-left"></i>
        </a>
      <% } %>

      <!-- Page Numbers -->
      <% for (let i = 1; i <= totalPages; i++) { %>
        <a 
          href="/admin/dashboard?page=<%= i %>&date=<%= selectedDate %><%= currentFilter ? '&estado=' + currentFilter : '' %>" 
          class="px-3.5 py-2 rounded-lg border text-sm transition font-semibold <%= currentPage === i ? 'bg-yellow-400 text-slate-950 border-yellow-400' : 'bg-white/5 border-white/10 text-purple-200/80 hover:bg-white/10' %>"
        >
          <%= i %>
        </a>
      <% } %>

      <!-- Next Page -->
      <% if (currentPage < totalPages) { %>
        <a 
          href="/admin/dashboard?page=<%= currentPage + 1 %>&date=<%= selectedDate %><%= currentFilter ? '&estado=' + currentFilter : '' %>" 
          class="px-3.5 py-2 rounded-lg bg-white/5 border border-white/10 hover:bg-white/10 text-purple-100 transition text-sm"
        >
          <i class="fa-solid fa-chevron-right"></i>
        </a>
      <% } %>
    </div>
  <% } %>
</div>

<!-- Simple Lightbox Modal -->
<div id="imageModal" class="fixed inset-0 bg-black/90 backdrop-blur-md hidden z-50 flex items-center justify-center p-4">
  <button id="closeModal" class="absolute top-4 right-4 text-white text-3xl font-bold hover:text-red-500 transition-colors duration-200" aria-label="Cerrar">&times;</button>
  <div class="max-w-4xl max-h-[85vh] relative">
    <img id="modalImg" class="max-w-full max-h-[80vh] rounded-xl shadow-2xl object-contain border border-white/10" src="" alt="Evidencia en pantalla completa">
  </div>
</div>

<script>
  // ============================================
  // 1. INICIALIZAR FLATPICKR
  // ============================================
  document.addEventListener('DOMContentLoaded', function() {
    const dateFilter = document.getElementById('dateFilter');
    const filterForm = document.getElementById('filterForm');
    const selectedDate = "<%= selectedDate %>";

    // Inicializar Flatpickr
    const fp = flatpickr(dateFilter, {
      dateFormat: "Y-m-d",
      defaultDate: selectedDate || new Date(),
      theme: "dark",
      disableMobile: true,
      allowInput: false,
      monthSelectorType: "dropdown",
      prevArrow: "‹",
      nextArrow: "›",
      locale: {
        firstDayOfWeek: 1,
        weekdays: {
          shorthand: ['Dom', 'Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb'],
          longhand: ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado']
        },
        months: {
          shorthand: ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'],
          longhand: ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre']
        }
      },
      // Auto-enviar el formulario al seleccionar fecha (opcional)
      onChange: function(selectedDates, dateStr, instance) {
        if (dateStr) {
          // Actualizar el valor y enviar el formulario automáticamente
          filterForm.submit();
        }
      }
    });

    // ============================================
    // 2. MODAL DE IMÁGENES
    // ============================================
    const modal = document.getElementById('imageModal');
    const modalImg = document.getElementById('modalImg');
    const closeModal = document.getElementById('closeModal');

    document.querySelectorAll('.view-img-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        modalImg.src = btn.getAttribute('data-img-url');
        modal.classList.remove('hidden');
        document.body.classList.add('overflow-hidden');
      });
    });

    const hideModal = () => {
      modal.classList.add('hidden');
      document.body.classList.remove('overflow-hidden');
    };

    closeModal.addEventListener('click', hideModal);

    modal.addEventListener('click', (e) => {
      if (e.target === modal || e.target === closeModal) {
        hideModal();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        hideModal();
      }
    });

    // ============================================
    // 3. OPCIONAL: Preservar filtros al recargar
    // ============================================
    // Si quieres que al recargar la página se mantenga el filtro
    // (ya lo haces con el value del input)
  });
</script>

<%- include('../partials/footer') %>
