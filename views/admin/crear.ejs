<%- include('../partials/header') %>

<div class="max-w-3xl mx-auto">
  <!-- Page Header -->
  <div class="mb-8 flex items-center justify-between border-b border-white/5 pb-4">
    <div>
      <h1 class="text-2xl font-extrabold text-white flex items-center gap-2">
        <i class="fa-solid fa-circle-plus text-yellow-400"></i>Crear Nueva Predicción
      </h1>
      <p class="text-xs text-purple-200/50 mt-1">Introduce los detalles del encuentro y la predicción seleccionada.</p>
    </div>
    <a href="/admin/dashboard" class="text-xs font-semibold bg-white/5 border border-white/10 px-3.5 py-2 rounded-lg hover:bg-white/10 transition flex items-center gap-1.5">
      <i class="fa-solid fa-arrow-left"></i>Cancelar
    </a>
  </div>

  <!-- Form Errors if any -->
  <% if (errors && errors.length > 0) { %>
    <div class="mb-6 bg-red-500/10 border border-red-500/20 text-red-400 px-4 py-3 rounded-xl space-y-1">
      <div class="font-bold text-sm flex items-center gap-1.5 mb-1 text-red-300">
        <i class="fa-solid fa-triangle-exclamation"></i>
        <span>Por favor, corrija los siguientes errores:</span>
      </div>
      <ul class="list-disc pl-5 text-xs space-y-1">
        <% errors.forEach(err => { %>
          <li><%= err.msg %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <!-- Creation Form -->
  <form action="/admin/crear" method="POST" enctype="multipart/form-data" class="bg-white/5 border border-white/10 rounded-2xl p-6 md:p-8 space-y-6">
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      
      <!-- Encounter name -->
      <div class="md:col-span-2">
        <label for="encuentro" class="block text-xs font-semibold text-purple-200/80 uppercase tracking-wider mb-2">
          Encuentro / Partido <span class="text-yellow-400">*</span>
        </label>
        <input 
          type="text" 
          name="encuentro" 
          id="encuentro" 
          required
          placeholder="Ej: Brasil vs Noruega" 
          value="<%= oldInput.encuentro || '' %>"
          class="w-full px-4 py-3 bg-black/40 border border-white/10 rounded-xl text-white placeholder-purple-200/25 text-sm focus:outline-none focus:border-yellow-400 focus:ring-1 focus:ring-yellow-400 transition"
        >
      </div>

      <!-- Date -->
      <div>
        <label for="fecha" class="block text-xs font-semibold text-purple-200/80 uppercase tracking-wider mb-2">
          Fecha del Partido <span class="text-yellow-400">*</span>
        </label>
        <input 
          type="date" 
          name="fecha" 
          id="fecha" 
          required
          value="<%= oldInput.fecha || '' %>"
          class="w-full px-4 py-3 bg-black/40 border border-white/10 rounded-xl text-white text-sm focus:outline-none focus:border-yellow-400 focus:ring-1 focus:ring-yellow-400 transition"
        >
      </div>

      <!-- Time -->
      <div>
        <label for="hora" class="block text-xs font-semibold text-purple-200/80 uppercase tracking-wider mb-2">
          Hora del Partido (HH:MM 24h) <span class="text-yellow-400">*</span>
        </label>
        <input 
          type="time" 
          name="hora" 
          id="hora" 
          required
          placeholder="Ej: 15:00"
          value="<%= oldInput.hora || '' %>"
          class="w-full px-4 py-3 bg-black/40 border border-white/10 rounded-xl text-white text-sm focus:outline-none focus:border-yellow-400 focus:ring-1 focus:ring-yellow-400 transition"
        >
      </div>

      <!-- Prediction Details -->
      <div class="md:col-span-2">
        <label for="prediccion" class="block text-xs font-semibold text-purple-200/80 uppercase tracking-wider mb-2">
          Detalle de la Predicción <span class="text-yellow-400">*</span>
        </label>
        <textarea 
          name="prediccion" 
          id="prediccion" 
          required
          rows="3"
          style="min-height: 80px;"
          placeholder="Ej: Total de Tiros de Esquina a favor de Brasil: Más de 4.5" 
          class="w-full px-4 py-3 bg-black/40 border border-white/10 rounded-xl text-white placeholder-purple-200/25 text-sm focus:outline-none focus:border-yellow-400 focus:ring-1 focus:ring-yellow-400 transition"
        ><%= oldInput.prediccion || '' %></textarea>
      </div>

      <!-- Odds -->
      <div>
        <label for="cuota" class="block text-xs font-semibold text-purple-200/80 uppercase tracking-wider mb-2">
          Cuota / Odds <span class="text-yellow-400">*</span>
        </label>
        <input 
          type="text" 
          name="cuota" 
          id="cuota" 
          required
          placeholder="Ej: 1.60" 
          value="<%= oldInput.cuota || '' %>"
          class="w-full px-4 py-3 bg-black/40 border border-white/10 rounded-xl text-white placeholder-purple-200/25 text-sm focus:outline-none focus:border-yellow-400 focus:ring-1 focus:ring-yellow-400 transition"
        >
      </div>

      <!-- State selection -->
      <div>
        <label for="estado" class="block text-xs font-semibold text-purple-200/80 uppercase tracking-wider mb-2">
          Estado <span class="text-yellow-400">*</span>
        </label>
        <select 
          name="estado" 
          id="estado" 
          required
          class="w-full px-4 py-3 bg-black/40 border border-white/10 rounded-xl text-white text-sm focus:outline-none focus:border-yellow-400 focus:ring-1 focus:ring-yellow-400 transition"
        >
          <option value="pendiente" <%= oldInput.estado === 'pendiente' ? 'selected' : '' %>>Pendiente</option>
          <option value="ganada" <%= oldInput.estado === 'ganada' ? 'selected' : '' %>>Ganada</option>
          <option value="perdida" <%= oldInput.estado === 'perdida' ? 'selected' : '' %>>Perdida</option>
        </select>
      </div>

      <!-- Additional Notes -->
      <div class="md:col-span-2">
        <label for="notas" class="block text-xs font-semibold text-purple-200/80 uppercase tracking-wider mb-2">
          Notas Adicionales (Opcional)
        </label>
        <textarea 
          name="notas" 
          id="notas" 
          rows="2"
          placeholder="Notas internas o comentarios adicionales sobre la apuesta..." 
          class="w-full px-4 py-3 bg-black/40 border border-white/10 rounded-xl text-white placeholder-purple-200/25 text-sm focus:outline-none focus:border-yellow-400 focus:ring-1 focus:ring-yellow-400 transition"
        ><%= oldInput.notas || '' %></textarea>
      </div>

      <!-- Image upload -->
      <div class="md:col-span-2">
        <label class="block text-xs font-semibold text-purple-200/80 uppercase tracking-wider mb-2">
          Imagen de Evidencia (Opcional)
        </label>
        <div class="relative border-2 border-dashed border-white/10 rounded-xl hover:border-yellow-400/50 transition duration-150 p-6 text-center bg-black/20">
          <input 
            type="file" 
            name="imagen" 
            id="imagen" 
            accept=".jpg,.jpeg,.png,.webp"
            class="absolute inset-0 w-full h-full opacity-0 cursor-pointer"
          >
          <div class="space-y-1.5">
            <i class="fa-solid fa-cloud-arrow-up text-3xl text-purple-400"></i>
            <p class="text-sm font-semibold text-white">Selecciona una imagen o arrástrala aquí</p>
            <p class="text-xs text-purple-200/40">Soporta: JPG, JPEG, PNG, WEBP (Max: 5MB)</p>
          </div>
        </div>

        <!-- Live image preview -->
        <div id="previewContainer" class="hidden mt-4 bg-black/30 p-4 border border-white/5 rounded-xl flex flex-col items-center">
          <span class="text-xs text-purple-300 font-semibold block mb-2 self-start">Vista previa del archivo seleccionado:</span>
          <img id="imagePreview" class="max-h-[220px] rounded-lg shadow-md object-contain border border-white/10" src="#" alt="Preview">
        </div>
      </div>

    </div>

    <!-- Actions -->
    <div class="flex items-center justify-end gap-3 pt-4 border-t border-white/5">
      <a 
        href="/admin/dashboard" 
        class="px-5 py-3 rounded-xl bg-white/5 border border-white/10 font-bold hover:bg-white/10 transition text-sm text-purple-100"
      >
        Cancelar
      </a>
      <button 
        type="submit" 
        class="px-6 py-3 bg-gradient-to-r from-yellow-400 to-orange-500 text-slate-950 font-extrabold rounded-xl shadow-lg hover:from-yellow-350 hover:to-orange-450 transition transform active:scale-95 text-sm flex items-center gap-1.5"
      >
        <i class="fa-solid fa-floppy-disk text-base"></i>
        <span>Guardar Predicción</span>
      </button>
    </div>

  </form>
</div>

<script>
  // Simple vanilla image preview script
  const imagenInput = document.getElementById('imagen');
  const previewContainer = document.getElementById('previewContainer');
  const imagePreview = document.getElementById('imagePreview');

  imagenInput.addEventListener('change', function() {
    const file = this.files[0];
    if (file) {
      const reader = new FileReader();
      reader.onload = function(e) {
        imagePreview.src = e.target.result;
        previewContainer.classList.remove('hidden');
      }
      reader.readAsDataURL(file);
    } else {
      previewContainer.classList.add('hidden');
    }
  });
</script>

<%- include('../partials/footer') %>
