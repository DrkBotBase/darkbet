<%- include('../partials/header') %>

<div class="max-w-md mx-auto my-12">
  <div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-3xl p-8 shadow-2xl">
    
    <!-- Title -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-yellow-400/10 text-yellow-400 border border-yellow-400/20 mb-4 text-xl">
        <i class="fa-solid fa-lock"></i>
      </div>
      <h2 class="text-2xl font-bold tracking-tight text-white">
        Acceso de Administrador
      </h2>
      <p class="text-purple-200/50 text-xs mt-1">
        Inicia sesión para gestionar las predicciones deportivas.
      </p>
    </div>

    <!-- Error message if available -->
    <% if (error) { %>
      <div class="mb-6 bg-red-500/10 border border-red-500/20 text-red-400 px-4 py-3 rounded-xl flex items-center space-x-2 text-sm">
        <i class="fa-solid fa-circle-exclamation text-base"></i>
        <span><%= error %></span>
      </div>
    <% } %>

    <!-- Login Form -->
    <form action="/admin/login" method="POST" class="space-y-6">
      
      <!-- Username Field -->
      <div>
        <label for="username" class="block text-xs font-semibold text-purple-200/80 uppercase tracking-wider mb-2">
          Usuario
        </label>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-purple-300/50">
            <i class="fa-solid fa-user"></i>
          </span>
          <input 
            type="text" 
            name="username" 
            id="username" 
            required
            placeholder="Introduce tu usuario admin" 
            class="w-full pl-10 pr-4 py-3 bg-black/40 border border-white/10 rounded-xl text-white placeholder-purple-200/30 text-sm focus:outline-none focus:border-yellow-400 focus:ring-1 focus:ring-yellow-400 transition"
          >
        </div>
      </div>

      <!-- Password Field -->
      <div>
        <label for="password" class="block text-xs font-semibold text-purple-200/80 uppercase tracking-wider mb-2">
          Contraseña
        </label>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-purple-300/50">
            <i class="fa-solid fa-key"></i>
          </span>
          <input 
            type="password" 
            name="password" 
            id="password" 
            required
            placeholder="••••••••" 
            class="w-full pl-10 pr-4 py-3 bg-black/40 border border-white/10 rounded-xl text-white placeholder-purple-200/30 text-sm focus:outline-none focus:border-yellow-400 focus:ring-1 focus:ring-yellow-400 transition"
          >
        </div>
      </div>

      <!-- Submit Button -->
      <button 
        type="submit" 
        class="w-full py-3 bg-gradient-to-r from-yellow-400 to-orange-500 text-slate-950 font-bold rounded-xl shadow-lg hover:from-yellow-350 hover:to-orange-450 focus:outline-none transition transform active:scale-95 flex items-center justify-center space-x-2 text-sm"
      >
        <i class="fa-solid fa-right-to-bracket"></i>
        <span>Iniciar Sesión</span>
      </button>

    </form>
  </div>
</div>

<%- include('../partials/footer') %>
